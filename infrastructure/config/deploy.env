#
# Copy to infrastructure/config/deploy.env and adjust values before running:
#   cp infrastructure/config/deploy.env.example infrastructure/config/deploy.env
#

# Public IP or reachable address of this VM. Used for Firefly APP_URL and access links.
FLOATING_IP="<FILLED-LATER>"

# Attached block volume to format/mount on first run if it has no filesystem yet.
DATA_VOLUME_DEVICE="/dev/vdb"
DATA_VOLUME_MOUNT_PATH="/data"
DATA_VOLUME_FILESYSTEM="ext4"

# K3s install settings.
K3S_INSTALL_CHANNEL="stable"
K3S_SERVER_EXTRA_ARGS="--write-kubeconfig-mode 644 --disable traefik"

# Optional. Leave true to install Terraform on the host for the Chameleon workflow too.
INSTALL_TERRAFORM="true"

# Secrets. Leave blank to auto-generate.
POSTGRES_PASSWORD="admin"
FIREFLY_APP_KEY=""
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadminpassword"

# Initial training bootstrap behavior.
INITIAL_TRAINING_WARMUP_SECONDS="600"
ACTIVE_MODEL_RETRY_SECONDS="120"
ACTIVE_MODEL_MAX_WAIT_SECONDS="36000"

# Monitoring.
DEPLOY_MONITORING="true"

